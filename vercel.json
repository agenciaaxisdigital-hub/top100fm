{
  "outputDirectory": "dist/client",
  "functions": {
    "api/handler.js": {
      "memory": 512,
      "includeFiles": "dist/server/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/handler" }
  ],
  "crons": [
    {
      "path": "/api/public/cron/news",
      "schedule": "0 9 * * *"
    }
  ]
}
